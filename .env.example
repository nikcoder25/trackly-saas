# Livesov SaaS - Server Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database URL (REQUIRED)
# Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (REQUIRED — must be set for auth to persist across deploys)
JWT_SECRET=livesov-super-secret-jwt-key-change-in-production

# AI Platform API Keys (add the ones you want to track)
# Supports multiple keys per platform for faster queries via round-robin rotation.
# Two formats supported (can be combined):
#   Format 1 — Comma-separated:  OPENAI_API_KEY=sk-key1,sk-key2,sk-key3
#   Format 2 — Numbered vars:    OPENAI_API_KEY_1=sk-key1
#                                 OPENAI_API_KEY_2=sk-key2
#                                 OPENAI_API_KEY_3=sk-key3
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=AIza...
CLAUDE_API_KEY=sk-ant-...
GROK_API_KEY=xai-...

# Google Sign-In (optional — enables "Continue with Google" on login page)
# Get your Client ID from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Admin Panel Secret (REQUIRED for /admin access)
# Used via X-Admin-Key header for secure admin authentication
ADMIN_SECRET=change-this-to-a-strong-secret

# ─── DodoPayments Configuration (for paid plan upgrades) ─────────
# Get your API key and webhook secret from https://app.dodopayments.com
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_RETURN_URL=https://yourdomain.com

# Product IDs for each plan (create subscription products in DodoPayments dashboard)
DODO_STARTER_PRODUCT_ID=
DODO_PRO_PRODUCT_ID=
DODO_AGENCY_PRODUCT_ID=
DODO_ENTERPRISE_PRODUCT_ID=

# ─── Email Configuration (optional — enables verification & password reset emails) ──
# If not set, emails are logged to console (dev mode)
# Uses Resend by default (https://resend.com). Also supports SendGrid.
EMAIL_FROM=Livesov <noreply@yourdomain.com>
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_API_URL defaults to Resend (https://api.resend.com/emails)
# For SendGrid, uncomment: EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send
APP_URL=https://yourdomain.com

# ─── Encryption Key (recommended — separate from JWT_SECRET) ────
# Used to encrypt user API keys at rest. Falls back to JWT_SECRET if not set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Production Settings ─────────────────────────────────────────
# NODE_ENV=production

# CORS allowed origins (REQUIRED in production)
# Comma-separated list of allowed frontend URLs
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Database SSL (optional) ─────────────────────────────────────
# Set to 'false' only if your DB provider uses self-signed certificates
# DB_SSL_REJECT_UNAUTHORIZED=false

# ─── Performance Tuning (optional) ──────────────────────────────
# PG_POOL_MAX=25
# CRON_BATCH_SIZE=5
# AI_REQUEST_TIMEOUT_MS=60000
# LOG_LEVEL=debug
