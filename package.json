{
  "name": "trackly-saas",
  "version": "1.0.0",
  "description": "AI Visibility Tracker - SaaS Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "npm run build:js && npm run build:css",
    "build:js": "terser public/js/app.js -o public/js/app.min.js -c -m --source-map",
    "build:css": "cleancss -o public/css/styles.min.css public/css/styles.css"
  },
  "dependencies": {
    "@dodopayments/express": "^0.2.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.46.1"
  }
}
