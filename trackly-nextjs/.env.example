# Livesov Next.js - Environment Variables
# Copy to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────────
# PostgreSQL Database (SAME as Express app - shared database)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# SSL cert verification (default: true in production, false in development)
# Set to 'false' only if your DB provider uses self-signed certificates
# DB_SSL_REJECT_UNAUTHORIZED=false
#
# CA certificate for managed databases signed by a private CA (e.g.
# DigitalOcean Managed PostgreSQL). Paste the provider's CA as raw PEM or
# base64-encoded PEM. With this set, full TLS verification works without the
# NODE_TLS_REJECT_UNAUTHORIZED=0 workaround.
# DATABASE_CA_CERT=
#
# WARNING: Do NOT set PGSSLMODE or NODE_TLS_REJECT_UNAUTHORIZED=0.
# SSL is configured per-connection via the pool's ssl option in db.ts.
#
# Connection pool sizing (defaults: max=50, min=5)
# PG_POOL_MAX=50
# PG_POOL_MIN=5

# ── Authentication ────────────────────────────────────────────
# JWT Secret (MUST match Express app's JWT_SECRET for shared auth)
JWT_SECRET=your-jwt-secret-here-min-32-chars

# Encryption Key (MUST match Express app for API key decryption)
ENCRYPTION_KEY=your-encryption-key-here
# Optional salt override; defaults to a built-in constant if omitted
ENCRYPTION_SALT=

# Google OAuth (public ID for the browser + server-only ID for token exchange;
# set both to the same value unless you intentionally use a separate server key)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Cloudflare Turnstile (contact form CAPTCHA). If both are unset the
# contact form skips verification silently, so set them in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── AI Platform API Keys ─────────────────────────────────────
# Anthropic / Claude (pool of up to 3 keys for rotation)
ANTHROPIC_API_KEY=
CLAUDE_API_KEY_1=
CLAUDE_API_KEY_2=
CLAUDE_API_KEY_3=

# OpenAI / ChatGPT (pool of up to 3 keys for rotation)
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=

# Google Gemini (pool of up to 3 keys for rotation)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# xAI Grok (pool of up to 3 keys for rotation)
GROK_API_KEY_1=
GROK_API_KEY_2=
GROK_API_KEY_3=

# Perplexity (pool of up to 3 keys for rotation)
PERPLEXITY_API_KEY_1=
PERPLEXITY_API_KEY_2=
PERPLEXITY_API_KEY_3=

# AI client tuning (optional; defaults in brackets)
# AI_REQUEST_TIMEOUT_MS=60000          [60s per model call]
# AI_DEEP_RETRY_BUDGET_MS=480000       [8min total retry budget per task]

# ── ChatGPT rate-limit tuning ─────────────────────────────────
# Root cause: OpenAI's default ChatGPT model `gpt-4o-mini-search-preview`
# runs on the Search-Preview rate-limit pool, which is much tighter than
# the standard gpt-4o/gpt-4o-mini pool. These knobs pace our calls to fit
# inside that pool and honour OpenAI's Retry-After / x-ratelimit-reset-*
# headers. Raise them if you upgrade OpenAI tier or switch to a non-
# search-preview model via site_config.platform_models.
# AI_CHATGPT_MAX_CONCURRENT=2          [semaphore for ChatGPT across process]
# AI_CHATGPT_MIN_DELAY_MS=1500         [per-key minimum spacing between calls]
# AI_CHATGPT_MAX_RETRIES=6             [429 retry budget inside fetchAI]
# AI_CHATGPT_MAX_RETRY_SLEEP_MS=60000  [cumulative sleep cap per call; longer
#                                       Retry-After values trigger deferred
#                                       in-process retry instead of burning
#                                       a local attempt]

# ── Per-platform daily web-search budget (feature flag, default OFF) ──
# Caps the number of search-enabled provider calls (Perplexity, ChatGPT
# *-search-preview / *-search-api) issued cluster-wide per UTC day. When
# the budget is exhausted AND a non-search fallback exists (ChatGPT's
# search-preview models drop to gpt-4o), the call is downgraded so it
# still completes but no longer spends search-tier quota. When no
# fallback exists (Perplexity is search-native), the call is allowed
# through with a warning log — fail-open by design, since this is a
# quota-saver and not a safety mechanism.
#
# Counter is keyed `search-budget:<platform>:YYYY-MM-DD` in Redis with
# atomic Lua check-then-INCR so concurrent pods cannot race past the
# limit. Fail-open on Redis outage; set AI_REDIS_REQUIRED=true to
# fail-closed (already wired for the rate limiter).
#
# AI_SEARCH_BUDGET_ENABLED=false        [master flag — leave OFF until validated]
# AI_SEARCH_BUDGET_DEFAULT=0            [default daily limit applied to every platform; 0 = unlimited]
# AI_SEARCH_BUDGET_CHATGPT=             [override for ChatGPT; e.g. 2000]
# AI_SEARCH_BUDGET_PERPLEXITY=          [override for Perplexity; e.g. 2000]

# ── ChatGPT smart model routing (feature flag, default OFF) ───
# When ON, non-search-intent queries (definitional/explanatory) are routed
# to gpt-4o instead of the search-preview model, sparing the preview
# quota for queries that genuinely need fresh web data. Conservative
# heuristic: defaults to search; only drops to gpt-4o when the query
# matches "what is / how does / explain / define" AND lacks freshness or
# location qualifiers. Ship OFF, validate via `[chatgpt.ratelimit]` logs
# for `event: smart_route`, then flip to 'true' in production.
# CHATGPT_SMART_MODEL_ROUTING=false

# ── Payments (DodoPayments) ──────────────────────────────────
# Get API key and webhook secret from https://app.dodopayments.com
# In production, all four DODO_* vars below MUST be set explicitly,
# DODO_PAYMENTS_ENVIRONMENT must be 'live_mode', and the return URL must
# match APP_URL. instrumentation.ts hard-fails the boot if these aren't met.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_RETURN_URL=https://livesov.com
# Set to 'true' to hit live.dodopayments.com; otherwise defaults to test.
DODO_LIVE_MODE=false

# Product IDs for each plan (create subscription products in DodoPayments dashboard)
DODO_STARTER_PRODUCT_ID=
DODO_PRO_PRODUCT_ID=
DODO_AGENCY_PRODUCT_ID=
DODO_ENTERPRISE_PRODUCT_ID=

# ── Email (Resend or SendGrid) ───────────────────────────────
EMAIL_API_KEY=
EMAIL_FROM=Livesov <noreply@livesov.com>
# Override transactional email endpoint (defaults to Resend)
# EMAIL_API_URL=https://api.resend.com/emails
RESEND_WEBHOOK_SECRET=
RESEND_AUDIENCE_ID=

# ── Background job queue (BullMQ / Redis) ────────────────────
# If unset, run-worker falls back to Next.js after() which is fine for
# dev but not for production scale. Required on DigitalOcean.
REDIS_URL=

# ── Anti-abuse (optional IP reputation providers) ────────────
IPQUALITYSCORE_KEY=
IPHUB_KEY=

# ── Trial / signup rate limits (optional; defaults shown) ─────
# TRIAL_DAILY_PROMPT_CAP_PER_USER=10
# TRIAL_DAILY_GLOBAL_PROMPT_CAP=5000
# SIGNUP_IP_BLOCK_HOURLY_LIMIT=5

# ── Zoho Mail SMTP (for contact form emails) ────────────────
# If ZOHO_SMTP_PASSWORD is set, contact form emails use Zoho SMTP instead of Resend
ZOHO_SMTP_HOST=smtppro.zoho.in
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=

# ── App Configuration ────────────────────────────────────────
# In production, APP_URL MUST be the public HTTPS origin (e.g. https://livesov.com)
# and ALLOWED_ORIGINS must list every origin allowed to call the API/CSRF flows.
# instrumentation.ts hard-fails boot in production if either is missing or set to
# a localhost value.
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# ── Analytics & Monitoring (Optional) ────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-M3E0LVFCEB
NEXT_PUBLIC_SENTRY_DSN=

# ── Admin & Security ─────────────────────────────────────────
ADMIN_SECRET=
INITIAL_ADMIN_EMAIL=
CRON_SECRET=
