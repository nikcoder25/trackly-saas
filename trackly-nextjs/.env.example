# Livesov Next.js - Environment Variables
# Copy to .env.local and fill in your values

# PostgreSQL Database (SAME as Express app - shared database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (MUST match Express app's JWT_SECRET for shared auth)
JWT_SECRET=your-jwt-secret-here

# Encryption Key (MUST match Express app for API key decryption)
ENCRYPTION_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# App URL
APP_URL=http://localhost:3000

# Email (Resend or SendGrid)
EMAIL_API_KEY=
EMAIL_FROM=Livesov <noreply@yourdomain.com>

# DodoPayments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Admin
ADMIN_SECRET=

# Node
NODE_ENV=development
